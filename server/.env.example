# ============================================================
# Solo Leveling — Server Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# From: Supabase Dashboard → Settings → API

# Public URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key (safe to expose — RLS is your security layer)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_anon_key

# Service role key (NEVER expose to the frontend — server-only)
# Used by cron jobs that need to bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# In development this should be the Vite dev server origin.
# In production, use your actual frontend domain.
ALLOWED_ORIGINS=http://localhost:5173

# ── Cron Security ────────────────────────────────────────────
# Secret used to authenticate internal cron job requests.
# Set this to any random 32+ character string.
# The cron caller must send: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace_with_a_random_secret_string_here

# ── Server Port ───────────────────────────────────────────────
# The Next.js dev server runs on port 3001 to avoid conflicts
# with other services. Set in package.json: "dev": "next dev -p 3001"
# This is not an env var — it's a CLI flag. Documented here for clarity.
# PORT=3001
