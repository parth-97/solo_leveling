# Supabase project credentials (Project Settings -> API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Base URL for the Next.js API routes (05_api_and_services.ts).
# In local dev with Next.js running alongside Vite, point this at it directly.
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Base URL for the Next.js API server (runs on port 3001 in local dev)
VITE_API_BASE_URL=http://localhost:3001/api/v1
